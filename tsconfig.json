{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "strict": true,
    "skipLibCheck": true,

    "noEmit": true,

    "types": ["node"],

    "lib": ["ESNext"],
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", ".yarn"],
}
