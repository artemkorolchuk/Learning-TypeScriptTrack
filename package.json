{
	"name": "learning-typescript-track",
	"private": true,
	"workspaces": [
		"packages/*"
	],
	"type": "module",
	"engines": {
		"node": ">=20"
	},
	"packageManager": "yarn@4.9.1",
	"scripts": {
		"lint": "turbo run lint",
		"typecheck": "turbo run typecheck",
		"test": "turbo run test",
		"lint:fix": "biome check . --write",
		"format": "biome format --write ."
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.16",
		"@types/node": "^25.9.2",
		"@vitest/coverage-v8": "^4.1.8",
		"tsx": "^4.22.4",
		"turbo": "^2.9.18",
		"typescript": "^6.0.3",
		"vitest": "^4.1.8"
	}
}
