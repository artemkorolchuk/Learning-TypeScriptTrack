{
	"$schema": "https://turbo.build/schema.json",
	"globalDependencies": ["tsconfig.base.json", "tsconfig.json", "biome.json"],
	"tasks": {
		"test": {
			"cache": true,
			"outputs": ["coverage/**"]
		},
		"typecheck": {
			"cache": true,
			"outputs": []
		},
		"lint": {
			"cache": true,
			"outputs": []
		},
		"lint:fix": {
			"cache": true,
			"outputs": []
		}
	}
}
